{
  "name": "integration-tests",
  "version": "1.0.0",
  "description": "Интеграционные тесты для API и БД",
  "scripts": {
    "test": "jest --runInBand --verbose",
    "test:api": "jest api/ --runInBand --verbose",
    "test:database": "jest database/ --runInBand --verbose",
    "test:watch": "jest --watch --runInBand",
    "test:coverage": "jest --coverage --runInBand",
    "test:ci": "jest --ci --coverage --runInBand --forceExit"
  },
  "dependencies": {
    "jest": "^29.5.0",
    "supertest": "^6.3.3",
    "axios": "^1.14.0",
    "@types/jest": "^29.5.0",
    "@types/supertest": "^2.0.12",
    "typescript": "^4.9.0",
    "ts-jest": "^29.1.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "setupFilesAfterEnv": ["<rootDir>/setup.js"],
    "testTimeout": 120000,
    "maxWorkers": 1,
    "collectCoverageFrom": [
      "**/*.{js,ts}",
      "!**/node_modules/**",
      "!**/coverage/**",
      "!jest.config.js",
      "!setup.ts"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": ["text", "lcov", "html"]
  }
}